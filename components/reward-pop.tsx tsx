'use client';
import { useEffect } from 'react';
import confetti from 'canvas-confetti';

export default function RewardPop({ message }: { message: string }) {
  useEffect(() => {
    confetti({ particleCount: 150, spread: 70 });
  }, []);
  return (
    <div className="fixed bottom-6 right-6 z-50 bg-green-600 px-8 py-6 rounded-3xl shadow-2xl text-white max-w-xs">
      💥 {message}
    </div>
  );
}
